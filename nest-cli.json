{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "apps/task-platform/src",
  "compilerOptions": {
    "deleteOutDir": true,
    "webpack": true,
    "tsConfigPath": "apps/task-platform/tsconfig.app.json"
  },
  "monorepo": true,
  "root": "apps/task-platform",
  "projects": {
    "reminder-worker": {
      "type": "application",
      "root": "apps/reminder-worker",
      "entryFile": "main",
      "sourceRoot": "apps/reminder-worker/src",
      "compilerOptions": {
        "tsConfigPath": "apps/reminder-worker/tsconfig.app.json"
      }
    },
    "task-platform": {
      "type": "application",
      "root": "apps/task-platform",
      "entryFile": "main",
      "sourceRoot": "apps/task-platform/src",
      "compilerOptions": {
        "tsConfigPath": "apps/task-platform/tsconfig.app.json"
      }
    }
  }
}